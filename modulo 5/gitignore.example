# ===== Exemplo de .gitignore =====
# Renomeie este arquivo para ".gitignore" na raiz do seu projeto
# e ajuste conforme a stack usada.

# --- Segredos e configuração local ---
.env
.env.*
*.pem
*.key
secrets.yaml

# --- Ambientes virtuais Python ---
venv/
.venv/
__pycache__/
*.pyc

# --- Dependências Node.js ---
node_modules/
npm-debug.log*
yarn-error.log*

# --- Builds e artefatos ---
dist/
build/
*.log

# --- Arquivos de sistema/IDE ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Dados e notebooks pesados (comum em projetos de dados) ---
*.csv
*.parquet
.ipynb_checkpoints/
